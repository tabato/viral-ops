# ──────────────────────────────────────────────────────────────
#  viral-ops · .env.example
#  Copy to .env in the project root and fill in your keys.
#  Never commit .env — it's already in .gitignore.
# ──────────────────────────────────────────────────────────────


# ── YouTube Data API v3 (required) ────────────────────────────
#
#  1. Go to: https://console.cloud.google.com/apis/library/youtube.googleapis.com
#  2. Enable "YouTube Data API v3"
#  3. Go to Credentials → Create API key
#
#  Free tier: 10,000 quota units/day
#  A typical viral-ops run uses ~60–80 units — plenty of headroom.

YOUTUBE_API_KEY=your_youtube_api_key_here


# ── AI Provider (set the one matching your profile.yml) ───────
#
#  See GEMINI.md or CLAUDE.md for full setup guides.


# ✨ GEMINI — FREE, no billing required (recommended)
#
#  Get a free key in 60 seconds: https://aistudio.google.com/app/apikey
#  Free tier: 15 req/min · 1M tokens/day · $0
#  Full guide: GEMINI.md

GEMINI_API_KEY=your_gemini_api_key_here


# CLAUDE — Paid, best for brand-voice copy angles
#
#  Get a key at: https://console.anthropic.com
#  Uses claude-sonnet-4-6 · ~$0.50 per full run
#  Full guide: CLAUDE.md

ANTHROPIC_API_KEY=your_anthropic_api_key_here
